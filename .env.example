PORT=3000
HOST=127.0.0.1
TMP_ROOT=/tmp/audiobook
MAX_TEXT_SIZE_MB=5
MAX_CONCURRENT_JOBS=2
CONCURRENT_TTS_LIMIT=2
CONCURRENT_TRANSCODE_LIMIT=3
# 全局语音合成引擎（前端不可选，仅由此处切换）：edge-tts | mimo-tts
DEFAULT_TTS_ENGINE=edge-tts
# edge-tts 引擎使用的音色：zh-CN-YunxiNeural | zh-CN-XiaoxiaoNeural | zh-CN-YunjianNeural
EDGE_VOICE=zh-CN-YunxiNeural
SUBPROCESS_TIMEOUT_MS=60000
GLOBAL_TASK_TIMEOUT_MS=3600000
# TTS_PROXY=http://127.0.0.1:7890
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# 小米 MiMo TTS 引擎（设 DEFAULT_TTS_ENGINE=mimo-tts 启用）。需在小米开放平台申请 API Key（当前限时免费）。
# 留空 MIMO_API_KEY 则 mimo-tts 引擎不可用，edge-tts 不受影响。
# MIMO_API_KEY=
# MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# MIMO_MODEL=mimo-v2.5-tts
# mimo-tts 引擎使用的音色：苏打 | 冰糖 | 茉莉 | 白桦 | mimo_default
# MIMO_VOICE=苏打
# MIMO_STYLE_PROMPT=平稳、自然、清晰的旁白朗读语气


# 腾讯云 COS 下载卸载（留空 COS_BUCKET 则禁用，下载走本地流式）
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=audiobook-1250000000
# COS_REGION=ap-guangzhou
# COS_KEY_PREFIX=audiobooks/
# COS_PRESIGN_TTL_S=3600
# 生产同地域 ECS 保持 true 走内网免费上传；本地非同地域开发置 false 走公网
# COS_USE_INTERNAL_UPLOAD=true
# 是否把成品 M4B 卸载到 COS 总开关，默认 false（仅本地留存）；需同时配好上面的 COS_* 才生效
# COS_UPLOAD_ENABLED=false


# 对话式 Agent（LangGraph.js 进程内）。AGENT_ENABLED=false 时不挂载 /agent/chat 路由，不影响 TTS 主链路。
# AGENT_ENABLED=false
# LLM 适配器：anthropic（Claude）| openai（含一切 OpenAI 兼容端点，如 MiMo，需配 AGENT_LLM_BASE_URL）
# AGENT_LLM_PROVIDER=anthropic
# 模型 ID：anthropic 如 claude-opus-4-8；openai 如 gpt-4o 或兼容端点的模型名
# AGENT_LLM_MODEL=claude-opus-4-8
# AGENT_LLM_API_KEY=
# 仅 provider=openai 时生效；指向 OpenAI 兼容端点，留空用官方默认
# AGENT_LLM_BASE_URL=https://api.xiaomimimo.com/v1
# 单轮工具调用循环上限，防止失控，默认 8
# AGENT_MAX_STEPS=8


# LangGraph 编排图（V2 阶段化有声书生成）。ORCHESTRATOR_ENABLED=false 时 runJob 走既有命令式流水线，行为不变。
# 开启后生成路由到 src/orchestrator/ 的阶段图：章节切分 → 逐章脚本对齐 → 声音分配 → TTS → 合并。
# ORCHESTRATOR_ENABLED=false

# DeepSeek 文本决策模型（编排图脚本情感/语速导演用；音频合成仍走 mimo-tts，与此解耦）。
# DEEPSEEK_API_KEY 留空或调用失败时，决策节点回退确定性标注（emotion=neutral、speedModifier=1.0），不阻塞生成。
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
