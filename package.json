{
  "name": "audiobook-generation-service",
  "version": "1.0.0",
  "description": "High-Performance Audiobook Generation Service using Fastify, Edge-TTS, and FFmpeg",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node build.js",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.3",
    "@fastify/cors": "^10",
    "@fastify/multipart": "^9",
    "cos-nodejs-sdk-v5": "^2.11.19",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-sse-v2": "^3.1.2",
    "https-proxy-agent": "^7.0.4",
    "iconv-lite": "^0.6.3",
    "jschardet": "^3.0.0",
    "msedge-tts": "^2.0.0",
    "p-limit": "^5.0.0",
    "typebox": "^1.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "esbuild": "^0.25.0",
    "eslint": "^9.1.1",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.1.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.7"
  }
}
